generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

// LOCAL DEV:  DATABASE_URL="file:./dev.db"
// DOCKER:     DATABASE_URL="file:/app/data/dev.db"  (volumen persistente en /app/data)
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  code         String   @unique
  passwordHash String
  role         String   @default("admin")
  fullName     String   @default("Administrador")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Group {
  id          String   @id @default(cuid())
  name        String
  course      String
  plant       String
  code        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  simulations Simulation[]
  members     Member[]
}

model Member {
  id        String   @id @default(cuid())
  groupId   String
  name      String
  role      String   @default("")
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Simulation {
  id          String   @id @default(cuid())
  groupId     String
  name        String
  description String   @default("")
  isDemo      Boolean  @default(false)
  isLocked    Boolean  @default(false)

  // Plant config
  plantName       String  @default("")
  initialHeight   Float   @default(2.0)
  baseGrowth      Float   @default(0.30)
  optimalTemp     Float   @default(18.0)
  optimalHumidity Float   @default(65.0)
  optimalLight    Float   @default(12.0)

  // Official prediction (locked before planting)
  officialPrediction Float?
  predictionNote     String @default("")
  startMonth         Int    @default(4)
  startYear          Int    @default(2026)
  startDay           Int    @default(0)
  projDays           Int    @default(45)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entries Entry[]
}

model Entry {
  id           String   @id @default(cuid())
  simulationId String
  sessionNum   Int
  date         DateTime @default(now())

  // Before measuring
  myPrediction Float?

  // After measuring
  realHeight   Float?
  temperature  Float?
  humidity     Float?
  lightHours   Float?
  note         String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  simulation Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
}
